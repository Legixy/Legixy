// ============================================================================
// OnyxLegal — Database Schema
// AI-Powered Contract & Compliance Operating System
// ============================================================================

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum Plan {
  FREE
  STARTER    // ₹999/mo
  GROWTH     // ₹2499/mo
  BUSINESS   // ₹4999/mo
}

enum ContractStatus {
  DRAFT
  IN_REVIEW
  SENT
  SIGNED
  ACTIVE
  EXPIRED
  TERMINATED
}

enum RiskLevel {
  SAFE
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ClauseType {
  PAYMENT_TERMS
  LIABILITY
  INDEMNIFICATION
  IP_OWNERSHIP
  CONFIDENTIALITY
  TERMINATION
  NON_COMPETE
  NON_SOLICITATION
  GOVERNING_LAW
  DISPUTE_RESOLUTION
  DATA_PROTECTION
  FORCE_MAJEURE
  AUTO_RENEWAL
  WARRANTY
  OTHER
}

enum AnalysisStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum AnalysisType {
  QUICK_SCAN        // Stage 1: clause extraction
  RISK_DETECTION    // Stage 2: risk scoring
  DEEP_ANALYSIS     // Stage 3: legal reasoning (GPT-4o)
  FIX_GENERATION    // Stage 4: suggested fixes
}

enum NotificationType {
  RISK_ALERT
  SIGNATURE_PENDING
  CONTRACT_EXPIRING
  AI_FIX_READY
  ANALYSIS_COMPLETE
  SYSTEM
}

enum TemplateCategory {
  NDA
  VENDOR_AGREEMENT
  EMPLOYMENT_OFFER
  SERVICE_AGREEMENT
  CONSULTING
  FREELANCER
  PARTNERSHIP
  CUSTOM
}

// ============================================================================
// CORE MODELS
// ============================================================================

/// Organization — multi-tenancy root
model Tenant {
  id        String   @id @default(cuid())
  name      String
  plan      Plan     @default(FREE)
  domain    String?  @unique  // e.g. "acme.com" for SSO future

  // AI token budget control
  aiTokensUsed  Int  @default(0)   // tokens consumed this billing cycle
  aiTokenLimit  Int  @default(5000) // limit per billing cycle

  billingCycleStart DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users     User[]
  contracts Contract[]
  templates Template[]  // custom templates only

  @@map("tenants")
}

/// User — authenticated individual
model User {
  id          String   @id @default(cuid())
  supabaseId  String   @unique  // links to Supabase Auth user
  tenantId    String
  email       String
  name        String?
  avatarUrl   String?
  role        UserRole @default(MEMBER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contracts     Contract[]     @relation("CreatedBy")
  notifications Notification[]

  @@unique([tenantId, email])
  @@index([supabaseId])
  @@map("users")
}

// ============================================================================
// CONTRACT SYSTEM
// ============================================================================

/// Template — system or custom contract templates
model Template {
  id          String           @id @default(cuid())
  tenantId    String?          // null = system template (available to all)
  category    TemplateCategory
  name        String
  description String?
  riskScore   Int              @default(95)  // AI-assessed template safety score

  // Structured clause blocks (JSON array of clause definitions)
  clauseBlocks Json  @default("[]")

  // Template metadata
  isSystem    Boolean @default(false)
  usageCount  Int     @default(0)
  socialProof String? // "Used by 850+ B2B SaaS startups"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant    Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contracts Contract[]

  @@index([category])
  @@index([isSystem])
  @@map("templates")
}

/// Contract — the core business entity
model Contract {
  id         String         @id @default(cuid())
  tenantId   String
  templateId String?
  createdById String

  title      String
  status     ContractStatus @default(DRAFT)
  riskScore  Int?           // 0-100, calculated by AI

  // Parties involved
  parties    Json  @default("[]")  // [{name, email, role: "client"|"vendor"|"employee"}]

  // Full contract content (rich text / HTML)
  content    String? @db.Text

  // Financial metadata (calculated by AI)
  contractValue    Decimal?  @db.Decimal(12, 2)
  currency         String    @default("INR")
  monthlyImpact    Decimal?  @db.Decimal(12, 2)  // ₹ risk per month

  // Lifecycle dates
  effectiveDate    DateTime?
  expirationDate   DateTime?
  signedAt         DateTime?
  lastReviewedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template   Template?          @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdBy  User               @relation("CreatedBy", fields: [createdById], references: [id])
  versions   ContractVersion[]
  clauses    Clause[]
  analyses   AIAnalysis[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("contracts")
}

/// ContractVersion — immutable version history
model ContractVersion {
  id         String @id @default(cuid())
  contractId String
  version    Int    // 1, 2, 3...
  content    String @db.Text
  changeNote String?
  changedBy  String // userId

  createdAt DateTime @default(now())

  // Relations
  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, version])
  @@map("contract_versions")
}

// ============================================================================
// AI ANALYSIS SYSTEM
// ============================================================================

/// Clause — individual clause extracted from a contract
model Clause {
  id         String    @id @default(cuid())
  contractId String
  type       ClauseType
  section    String?   // e.g. "Section 4.2"

  originalText  String @db.Text
  suggestedText String? @db.Text  // AI-suggested improvement
  riskLevel     RiskLevel @default(SAFE)
  riskReason    String?   // Human-readable risk explanation

  // Financial impact of this clause
  estimatedImpact Decimal? @db.Decimal(12, 2)
  impactPeriod    String?  // "monthly", "annually", "one-time"

  isAccepted Boolean @default(false)  // user accepted AI suggestion

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([riskLevel])
  @@map("clauses")
}

/// AIAnalysis — async AI job tracking
model AIAnalysis {
  id         String         @id @default(cuid())
  contractId String
  type       AnalysisType
  status     AnalysisStatus @default(QUEUED)

  // Cost tracking
  tokensUsed    Int    @default(0)
  modelUsed     String? // "gpt-4o-mini" or "gpt-4o"
  processingMs  Int?    // execution time in ms

  // Error handling
  errorMessage String?
  retryCount   Int @default(0)

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  // Relations
  contract     Contract      @relation(fields: [contractId], references: [id], onDelete: Cascade)
  riskFindings RiskFinding[]

  @@index([contractId, type])
  @@index([status])
  @@map("ai_analyses")
}

/// RiskFinding — individual risk item from AI analysis
model RiskFinding {
  id         String    @id @default(cuid())
  analysisId String
  severity   RiskLevel
  title      String    // "Uncapped Liability"
  clause     String    @db.Text  // the problematic clause text
  impact     String    // "Exposes company to unlimited financial liability"
  suggestion String    @db.Text  // AI-suggested fix
  legalRef   String?   // "Indian Contract Act, Section 27"

  // Financial impact
  estimatedRisk Decimal? @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  // Relations
  analysis AIAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@map("risk_findings")
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

/// Notification — in-app alerts
model Notification {
  id       String           @id @default(cuid())
  userId   String
  type     NotificationType
  title    String
  body     String
  read     Boolean @default(false)

  // Deep link
  actionUrl String?  // "/dashboard/contracts/clxyz123"

  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}
